# vault-os Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Never commit .env to version control.

# =============================================================================
# REQUIRED — Core paths
# =============================================================================

# Absolute path to your Obsidian vault (Knowledge Base root)
VAULT_PATH=C:\vault\Knowledge_Base

# Absolute path to your content pipeline directory
CONTENT_PIPELINE_DIR=C:\vault\ContentPipeline

# =============================================================================
# REQUIRED — Dashboard
# =============================================================================

# Port for the dashboard web server
PORT=3777

# =============================================================================
# REQUIRED — Telegram Bot (for Quick Capture)
# =============================================================================

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# =============================================================================
# REQUIRED — Anthropic API (for AI features via claude CLI)
# =============================================================================

# Your Anthropic API key — https://console.anthropic.com
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# =============================================================================
# OPTIONAL — Whisper.cpp (for voice transcription in Telegram)
# =============================================================================

# Full path to the whisper-cli executable
# Leave empty to disable voice transcription
WHISPER_CLI=C:\tools\whisper-cpp\Release\whisper-cli.exe

# Whisper model filename (must be in the models/ folder next to the binary)
# Options: ggml-tiny.bin, ggml-base.bin, ggml-small.bin, ggml-medium.bin
WHISPER_MODEL=ggml-small.bin

# Language code for transcription (e.g. en, tr, de, fr, es)
WHISPER_LANG=en

# =============================================================================
# OPTIONAL — Notion Sync
# =============================================================================

# Notion integration token — https://www.notion.so/my-integrations
NOTION_TOKEN=YOUR_NOTION_TOKEN

# =============================================================================
# OPTIONAL — Disk Sync (h-disk-sync.ps1)
# =============================================================================

# Semicolon-separated list of directories to scan for changed .md files
# Example: C:\projects;C:\work\notes
DATA_SCAN_PATHS=C:\projects

# =============================================================================
# OPTIONAL — VPS / Service monitoring
# =============================================================================

# Your server IP (shown in dashboard sidebar)
VPS_IP=your-server-ip

# Comma-separated list of services to monitor: "Name|URL"
# Example: MyApp|https://myapp.com,n8n|https://n8n.yourdomain.com
MONITORED_SERVICES=MyApp|https://myapp.com

# n8n automation URL
N8N_URL=http://localhost:5678

# =============================================================================
# OPTIONAL — Local database TCP port checks (dashboard MCP status panel)
# =============================================================================

DB1_PORT=5432
DB2_PORT=5433
DB3_PORT=5434

# =============================================================================
# OPTIONAL — Projects (for nightly agent and dashboard)
# =============================================================================
# Define up to N projects using PROJECT_n_* variables.
# The dashboard PROJECTS array in server.js takes precedence if you edit it directly.

PROJECT_1_ID=MyProject
PROJECT_1_PATH=C:\projects\my-project
PROJECT_1_STATUS=Active
PROJECT_1_COLOR=blue
PROJECT_1_URL=https://myproject.com
PROJECT_1_DESC=My main project

# PROJECT_2_ID=AnotherProject
# PROJECT_2_PATH=C:\projects\another
# PROJECT_2_STATUS=Planning
# PROJECT_2_COLOR=yellow
# PROJECT_2_URL=
# PROJECT_2_DESC=Another project
